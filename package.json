{
  "name": "blog-system",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "install:all": "npm install --workspaces",
    "prisma:generate": "npm run prisma:generate --workspace backend",
    "prisma:push": "npm run prisma:push --workspace backend",
    "prisma:migrate": "npm run prisma:migrate --workspace backend",
    "dev": "npm run dev --workspace frontend",
    "dev:frontend": "npm run dev --workspace frontend",
    "dev:backend": "npm run start:dev --workspace backend",
    "lint": "npm run lint --workspace frontend && npm run lint:check --workspace backend",
    "test": "npm run test --workspace backend -- --runInBand",
    "build": "npm run build --workspace frontend && npm run build --workspace backend",
    "ci": "npm run lint && npm run build && npm run test",
    "deploy": "bash scripts/deploy.sh",
    "deploy:down": "bash scripts/deploy-down.sh"
  }
}
